{
  "problemMatcher": [
    {
      "owner": "prettier-pretty-check",
      "severity": "error",
      "pattern": [
        {
          "regexp": "^(.+):(\\d+):(\\d+): error: (.+) \\(prettier/(.+)\\)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "message": 4,
          "code": 5
        }
      ]
    }
  ]
}
